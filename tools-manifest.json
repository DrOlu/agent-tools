{
  "_comment": "Manifest of agent-tools auto-updated from upstream GitHub releases (Windows x64). Each tool: fetch latest release of `repo`, match `asset_glob` (prefer amd64/x64), compare tag to .tool-versions.json, and if newer: download, unzip if `zip`, extract each output (renaming to canonical name), then store. storage='tree' (default) writes the file into the repo working tree (committed by the workflow); storage='release' uploads it as an asset on this repo's 'large-binaries' GitHub release (for files >100MB that GitHub refuses in normal git). A tool may produce multiple `outputs` from one zip (e.g. uv -> uv.exe+uvw.exe+uvx.exe; ngrep -> ngrep.exe+pcre2-8.dll).",
  "tools": [
    {
      "name": "jq.exe",
      "repo": "jqlang/jq",
      "asset_glob": "jq-windows-amd64*.exe",
      "zip": false
    },
    {
      "name": "rg.exe",
      "repo": "BurntSushi/ripgrep",
      "asset_glob": "ripgrep-*-x86_64-pc-windows-msvc.zip",
      "zip": true,
      "exe_glob": "**/rg.exe"
    },
    {
      "name": "nats.exe",
      "repo": "nats-io/natscli",
      "asset_glob": "nats-*-windows-amd64.zip",
      "zip": true,
      "exe_glob": "**/nats.exe"
    },
    {
      "name": "nats-server.exe",
      "repo": "nats-io/nats-server",
      "asset_glob": "nats-server-v*-windows-amd64.zip",
      "zip": true,
      "exe_glob": "**/nats-server.exe"
    },
    {
      "name": "himalaya.exe",
      "repo": "pimalaya/himalaya",
      "asset_glob": "himalaya.x86_64-windows.zip",
      "zip": true,
      "exe_glob": "**/himalaya.exe"
    },
    {
      "name": "netwatch.exe",
      "repo": "matthart1983/netwatch",
      "asset_glob": "netwatch-windows-x86_64*.zip",
      "zip": true,
      "exe_glob": "**/netwatch.exe"
    },
    {
      "name": "rustnet.exe",
      "repo": "domcyrus/rustnet",
      "asset_glob": "rustnet-*-x86_64-pc-windows-msvc.zip",
      "zip": true,
      "exe_glob": "**/rustnet.exe"
    },
    {
      "name": "websocat.exe",
      "repo": "vi/websocat",
      "asset_glob": "websocat.x86_64-pc-windows-gnu.exe",
      "zip": false
    },
    {
      "name": "websocketd.exe",
      "repo": "joewalnes/websocketd",
      "asset_glob": "websocketd-*-windows_amd64.zip",
      "zip": true,
      "exe_glob": "**/websocketd.exe"
    },
    {
      "name": "task.exe",
      "repo": "go-task/task",
      "asset_glob": "task_windows_amd64.zip",
      "zip": true,
      "exe_glob": "**/task.exe"
    },
    {
      "_comment": "uv ships uv.exe + uvw.exe + uvx.exe together in one Windows zip",
      "repo": "astral-sh/uv",
      "asset_glob": "uv-x86_64-pc-windows-msvc.zip",
      "zip": true,
      "outputs": [
        {"exe_glob": "**/uv.exe",  "name": "uv.exe"},
        {"exe_glob": "**/uvw.exe", "name": "uvw.exe"},
        {"exe_glob": "**/uvx.exe", "name": "uvx.exe"}
      ]
    },
    {
      "name": "kagent.exe",
      "repo": "kagent-dev/kagent",
      "asset_glob": "kagent-windows-amd64.exe",
      "zip": false
    },
    {
      "name": "multica.exe",
      "repo": "multica-ai/multica",
      "asset_glob": "multica-cli-*-windows-amd64.zip",
      "zip": true,
      "exe_glob": "**/multica*.exe"
    },
    {
      "name": "opensre.exe",
      "repo": "Tracer-Cloud/opensre",
      "asset_glob": "opensre_*_windows-x64.zip",
      "zip": true,
      "exe_glob": "**/opensre.exe"
    },
    {
      "name": "stakpak.exe",
      "repo": "stakpak/agent",
      "asset_glob": "stakpak-windows-x86_64.zip",
      "zip": true,
      "exe_glob": "**/stakpak.exe"
    },
    {
      "name": "agentsecrets.exe",
      "repo": "The-17/agentsecrets",
      "asset_glob": "agentsecrets_*_windows_amd64.zip",
      "zip": true,
      "exe_glob": "**/agentsecrets.exe"
    },
    {
      "name": "scrt.exe",
      "repo": "loderunner/scrt",
      "asset_glob": "scrt_*_windows_x86_64.zip",
      "zip": true,
      "exe_glob": "**/scrt.exe"
    },
    {
      "name": "wtrace.exe",
      "repo": "lowleveldesign/wtrace",
      "asset_glob": "wtrace.zip",
      "zip": true,
      "exe_glob": "**/wtrace.exe"
    },
    {
      "name": "psmux.exe",
      "repo": "psmux/psmux",
      "asset_glob": "psmux-v*-windows-x64.zip",
      "zip": true,
      "exe_glob": "**/psmux.exe"
    },
    {
      "name": "dev-browser.exe",
      "repo": "SawyerHood/dev-browser",
      "asset_glob": "dev-browser-windows-x64.exe",
      "zip": false
    },
    {
      "name": "sshpass.exe",
      "repo": "xhcoding/sshpass-win32",
      "asset_glob": "sshpass.exe",
      "zip": false
    },
    {
      "name": "agentspan.exe",
      "repo": "agentspan-ai/agentspan",
      "asset_glob": "agentspan_windows_amd64.exe",
      "zip": false
    },
    {
      "name": "vshell.exe",
      "repo": "veithly/vibeshell",
      "asset_glob": "vshell-*-windows-x64.exe",
      "zip": false
    },
    {
      "name": "agent-browser.exe",
      "repo": "vercel-labs/agent-browser",
      "asset_glob": "agent-browser-win32-x64.exe",
      "zip": false
    },
    {
      "_comment": "ngrep zip bundles ngrep.exe + pcre2-8.dll (its runtime dependency)",
      "repo": "jpr5/ngrep",
      "asset_glob": "ngrep-windows-x86_64.zip",
      "zip": true,
      "outputs": [
        {"exe_glob": "**/ngrep.exe",    "name": "ngrep.exe"},
        {"exe_glob": "**/pcre2-8.dll",  "name": "pcre2-8.dll"}
      ]
    },
    {
      "name": "dbcli.exe",
      "repo": "tteamtm/dbcli",
      "asset_glob": "dbcli-win-x64-*.zip",
      "zip": true,
      "exe_glob": "**/dbcli.exe"
    },
    {
      "_comment": "spiceai ships as .tar.gz (not zip); uses tar:true to extract spice.exe",
      "name": "spice.exe",
      "repo": "spiceai/spiceai",
      "asset_glob": "spice.exe_windows_x86_64.tar.gz",
      "tar": true,
      "exe_glob": "**/spice.exe"
    },
    {
      "_comment": "surrealdb ships a standalone .exe (>100MB → release storage)",
      "name": "surreal.exe",
      "repo": "surrealdb/surrealdb",
      "asset_glob": "surreal-*.windows-amd64.exe",
      "zip": false,
      "storage": "release"
    },
    {
      "_comment": "inngest.exe inside zip is >100MB → release storage",
      "name": "inngest.exe",
      "repo": "inngest/inngest",
      "asset_glob": "inngest_*_windows_amd64.zip",
      "zip": true,
      "exe_glob": "**/inngest.exe",
      "storage": "release"
    },
    {
      "_comment": "temporal tools (<100MB each → tree storage) from the temporal Windows zip",
      "repo": "temporalio/temporal",
      "asset_glob": "temporal_*_windows_amd64.zip",
      "zip": true,
      "outputs": [
        {"exe_glob": "**/tdbg.exe",                     "name": "tdbg.exe"},
        {"exe_glob": "**/temporal-sql-tool.exe",         "name": "temporal-sql-tool.exe"},
        {"exe_glob": "**/temporal-cassandra-tool.exe",  "name": "temporal-cassandra-tool.exe"},
        {"exe_glob": "**/temporal-elasticsearch-tool.exe", "name": "temporal-elasticsearch-tool.exe"}
      ]
    },
    {
      "_comment": "temporal-server.exe >100MB → release storage (same zip, separate entry)",
      "name": "temporal-server.exe",
      "repo": "temporalio/temporal",
      "asset_glob": "temporal_*_windows_amd64.zip",
      "zip": true,
      "exe_glob": "**/temporal-server.exe",
      "storage": "release"
    },
    {
      "_comment": "uiacli: Windows UI Automation CLI for AI agents. Self-contained .NET+Go deployment (200MB, 610 files). Store the entire zip as a release asset — no extraction.",
      "name": "uiacli-v0.1.0-win-x64.zip",
      "repo": "amitse/uiacli",
      "asset_glob": "uiacli-*-win-x64.zip",
      "zip": false,
      "store_archive": true,
      "storage": "release"
    },
    {
      "_comment": "Terax: lightweight terminal-first AI-native dev workspace (Tauri 2 + Rust). Windows NSIS installer stored in tree.",
      "name": "Terax-setup.exe",
      "repo": "crynta/terax-ai",
      "asset_glob": "Terax_*_x64-setup.exe",
      "zip": false
    },
    {
      "name": "zero.exe",
      "repo": "vercel-labs/zerolang",
      "asset_glob": "zero-win32-x64.exe",
      "zip": false
    },
    {
      "_comment": ">100MB: stored as a release asset on this repo's 'large-binaries' release, not in the git tree",
      "name": "opencode.exe",
      "repo": "sst/opencode",
      "asset_glob": "opencode-windows-x64.zip",
      "zip": true,
      "exe_glob": "**/opencode.exe",
      "storage": "release"
    },
    {
      "_comment": ">100MB: pi.exe (oh-my-pi) renamed to omp.exe; stored as release asset",
      "name": "omp.exe",
      "repo": "earendil-works/pi",
      "asset_glob": "pi-windows-x64.zip",
      "zip": true,
      "exe_glob": "**/pi.exe",
      "storage": "release"
    },
    {
      "name": "usql.exe",
      "repo": "xo/usql",
      "asset_glob": "usql-*-windows-amd64.zip",
      "zip": true,
      "exe_glob": "**/usql.exe",
      "storage": "release"
    }
  ]
}
